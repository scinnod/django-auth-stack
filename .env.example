# =============================================================================
# Django Auth Stack Environment Configuration (Keycloak)
# =============================================================================
# Example configuration file for the Keycloak-based edge authentication stack.
# Copy this file to .env and replace placeholder values with your actual config.
#
# SECURITY WARNING: Keep .env file secure! It contains sensitive credentials.
# The .env file is in .gitignore to prevent accidental commits.
#
# TIP: Run ./scripts/configure-env.sh to auto-generate passwords and configure services.
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL Configuration
# -----------------------------------------------------------------------------
POSTGRES_DB=keycloak
POSTGRES_USER=keycloak
# REQUIRED: Generate with: openssl rand -base64 32
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

# -----------------------------------------------------------------------------
# Keycloak Configuration
# -----------------------------------------------------------------------------
KEYCLOAK_VERSION=23.0

# Admin credentials (CHANGE THESE AFTER FIRST LOGIN!)
KEYCLOAK_ADMIN=admin
# REQUIRED: Generate with: openssl rand -base64 20
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD

# Realm name for your applications
KEYCLOAK_REALM=jade

# Log level: info, debug, warn, error
KEYCLOAK_LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Keycloak Admin Console Security
# -----------------------------------------------------------------------------
# Optional: Restrict admin console access to specific IP addresses/networks.
# Format: SPACE-SEPARATED list of IP addresses or CIDR blocks (NOT comma-separated).
# If empty, admin console is accessible from any IP (still requires authentication).
#
# Examples:
#   Single IP:        KEYCLOAK_ADMIN_ALLOWED_IPS=192.168.1.100
#   Multiple IPs:     KEYCLOAK_ADMIN_ALLOWED_IPS=192.168.1.100 10.0.0.50
#   CIDR notation:    KEYCLOAK_ADMIN_ALLOWED_IPS=10.0.0.0/8 192.168.0.0/16
#   Office + VPN:     KEYCLOAK_ADMIN_ALLOWED_IPS=203.0.113.0/24 10.8.0.0/24
#   Localhost only:   KEYCLOAK_ADMIN_ALLOWED_IPS=127.0.0.1 ::1
#   No restriction:   KEYCLOAK_ADMIN_ALLOWED_IPS=
#
# SECURITY NOTE: Even without IP restriction, admin console is protected by:
# - Keycloak admin username/password authentication
# - Strict rate limiting (5 req/s, burst 10) on admin paths only
# - Enhanced security headers (CSP, no-cache, X-Frame-Options: DENY)
#
KEYCLOAK_ADMIN_ALLOWED_IPS=

# -----------------------------------------------------------------------------
# OAuth2 Proxy Configuration
# -----------------------------------------------------------------------------
# Client ID must match the OIDC client created in Keycloak
OAUTH2_PROXY_CLIENT_ID=oauth2-proxy

# Client secret: Get this from Keycloak after creating the OIDC client
# Go to: Clients → oauth2-proxy → Credentials tab
OAUTH2_PROXY_CLIENT_SECRET=REPLACE_WITH_KEYCLOAK_CLIENT_SECRET

# Cookie secret: Generate with: openssl rand -base64 32 | head -c 32
OAUTH2_PROXY_COOKIE_SECRET=REPLACE_WITH_32_CHAR_RANDOM_STRING

# Cookie domain for SSO across subdomains (must include leading dot)
# For .local domains: .example.local
# For public domains: .example.com
OAUTH2_PROXY_COOKIE_DOMAIN=.example.local

OAUTH2_PROXY_VERSION=v7.6.0

# -----------------------------------------------------------------------------
# Domain Configuration
# -----------------------------------------------------------------------------
# Auth domain (Keycloak admin console)
# For development: Use .local domains and add to /etc/hosts
# For production: Use your actual domains with valid DNS/TLS
DOMAIN_AUTH=auth.example.local

# -----------------------------------------------------------------------------
# TLS/SSL Configuration
# -----------------------------------------------------------------------------
# Set to 'true' to enable Let's Encrypt (certbot) certificate management.
# When enabled, generate-compose-override.sh will include the certbot service
# and volumes in the override file, so 'docker compose up -d' just works.
LETSENCRYPT_ENABLED=false

# Email for Let's Encrypt certificate notifications (required when enabled)
LETSENCRYPT_EMAIL=admin@example.com

# -----------------------------------------------------------------------------
# Nginx Configuration
# -----------------------------------------------------------------------------
# Maximum request body size (for file uploads)
CLIENT_MAX_BODY_SIZE=50M

# Proxy timeout settings
PROXY_CONNECT_TIMEOUT=60s
PROXY_SEND_TIMEOUT=60s
PROXY_READ_TIMEOUT=60s

# =============================================================================
# UPSTREAM SERVICES CONFIGURATION
# =============================================================================
# Define the services you want to protect with Keycloak authentication.
# Each service requires the following variables:
#
#   SERVICE_<N>_NAME      - Unique name (lowercase, used for config files)
#   SERVICE_<N>_ENABLED   - true/false (toggle service on/off)
#   SERVICE_<N>_PATTERN   - Authentication pattern: A or B
#                           A = Django-controlled (public + protected pages)
#                           B = Full nginx-level auth (everything protected)
#   SERVICE_<N>_DOMAIN    - Domain name for this service
#   SERVICE_<N>_UPSTREAM  - Container:port (e.g., myapp_nginx:8000)
#   SERVICE_<N>_NETWORK   - Docker network name (external network)
#   SERVICE_<N>_MAX_BODY_SIZE - (Optional) Max upload size for this service
#                           Overrides the global CLIENT_MAX_BODY_SIZE.
#                           Format: number + unit (e.g., 55M, 100M, 1G)
#                           If omitted, falls back to CLIENT_MAX_BODY_SIZE (50M)
#
# Services are numbered sequentially starting from 1.
# You can have 0 or more services.
# =============================================================================

# --- Example Service 1: ITSM (Django with public pages) ---
# SERVICE_1_NAME=itsm
# SERVICE_1_ENABLED=true
# SERVICE_1_PATTERN=A
# SERVICE_1_DOMAIN=itsm.example.local
# SERVICE_1_UPSTREAM=itsm_nginx:8000
# SERVICE_1_NETWORK=itsm_backend
# SERVICE_1_MAX_BODY_SIZE=50M

# --- Example Service 2: Translation (fully protected internal tool) ---
# SERVICE_2_NAME=translation
# SERVICE_2_ENABLED=true
# SERVICE_2_PATTERN=B
# SERVICE_2_DOMAIN=translation.example.local
# SERVICE_2_UPSTREAM=translation_nginx:8000
# SERVICE_2_NETWORK=translation_backend
# SERVICE_2_MAX_BODY_SIZE=100M

# --- Example Service 3: Admin Dashboard (disabled) ---
# SERVICE_3_NAME=admin
# SERVICE_3_ENABLED=false
# SERVICE_3_PATTERN=B
# SERVICE_3_DOMAIN=admin.example.local
# SERVICE_3_UPSTREAM=admin_app:3000
# SERVICE_3_NETWORK=admin_backend
