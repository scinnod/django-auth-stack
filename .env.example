# =============================================================================
# Edge-Auth Stack Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values
# 
# SECURITY WARNING: Keep .env file secure! It contains sensitive credentials.
# Add .env to .gitignore to prevent accidental commits.
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL Configuration
# -----------------------------------------------------------------------------
POSTGRES_DB=authentik
POSTGRES_USER=authentik
# REQUIRED: Set a strong password (min 20 chars recommended)
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

# -----------------------------------------------------------------------------
# Authentik Configuration
# -----------------------------------------------------------------------------
# REQUIRED: Generate with: openssl rand -base64 60
AUTHENTIK_SECRET_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND

# Authentik version (update as needed)
AUTHENTIK_VERSION=2024.10.1

# Authentik public URL (must match DOMAIN_AUTH)
# This tells Authentik its own public URL for redirects and outpost configuration
AUTHENTIK_HOST=https://auth.example.org
AUTHENTIK_HOST_BROWSER=https://auth.example.org

# Cookie domain for SSO across subdomains (include leading dot)
# This allows authentication cookies to work across itsm.example.org, deepl.example.org, etc.
AUTHENTIK_COOKIE_DOMAIN=.example.org

# -----------------------------------------------------------------------------
# Email Configuration (Optional - for password resets, notifications)
# -----------------------------------------------------------------------------
# Uncomment and configure for production use
AUTHENTIK_EMAIL_HOST=
AUTHENTIK_EMAIL_PORT=587
AUTHENTIK_EMAIL_USERNAME=
AUTHENTIK_EMAIL_PASSWORD=
AUTHENTIK_EMAIL_USE_TLS=true
AUTHENTIK_EMAIL_FROM=

# -----------------------------------------------------------------------------
# Domain Configuration
# -----------------------------------------------------------------------------
# These are used in nginx configs (can be overridden per config file)
DOMAIN_ITSM=itsm.example.org
DOMAIN_DEEPL=deepl.example.org
DOMAIN_AUTH=auth.example.org

# -----------------------------------------------------------------------------
# TLS/SSL Configuration
# -----------------------------------------------------------------------------
# For Let's Encrypt mode
LETSENCRYPT_EMAIL=admin@example.org

# -----------------------------------------------------------------------------
# Nginx Configuration
# -----------------------------------------------------------------------------
# Client max body size (for file uploads)
CLIENT_MAX_BODY_SIZE=50M

# Proxy timeouts
PROXY_CONNECT_TIMEOUT=60s
PROXY_SEND_TIMEOUT=60s
PROXY_READ_TIMEOUT=60s
